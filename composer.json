{
    "name": "hydrakit/session",
    "description": "Session library for Hydra PHP framework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hydra\\Session\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hydra\\Session\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../core", "options": { "symlink": true } }
    ],
    "authors": [
        {
            "name": "William Hleucka",
            "email": "william.hleucka@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "hydrakit/core": "^0.1",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
